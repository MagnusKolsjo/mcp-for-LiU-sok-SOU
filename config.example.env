# API-nyckel från Linköpings universitetsbibliotek
# Testnyckel: test (max 5 träffar per sökning)
# Fullständig nyckel: begärs via e-post till Anders Fåk, LiU-biblioteket
LIU_API_KEY=din_nyckel_har

# Bas-URL för LiU:s SOU-API
LIU_API_BASE=https://www2.bibl.liu.se/api/sou_api/getdata.aspx

# Lokal filcache för PDF-filer under nedladdning och extraktion
# Relativa sökvägar ankras mot skriptets mapp (inte processens cwd)
PDF_CACHE_DIR=./pdf_cache

# Antal dagar en PDF-fil bevaras efter att fulltexten sparats i databasen.
# Pipeline raderar alltid direkt efter lyckad extraktion — detta är en säkerhetsventil.
# Standard: 1 dag
PDF_CACHE_TTL_DAGAR=1

# Transportläge för MCP-servern: stdio (standard) eller http
MCP_TRANSPORT=stdio

# Inställningar för HTTP-transport (används bara om MCP_TRANSPORT=http)
# MCP_HOST=127.0.0.1
# MCP_PORT=8004
# MCP_API_KEY=generera_med_secrets_token_hex_32

# Databasanslutning
# PostgreSQL (rekommenderas — delar databas med övriga arbetsströmmar via schema liu_sou)
DATABASE_URL=postgresql://mitt_db_anvandare:byt_till_eget_starkt_losenord@localhost:5432/riksdagstryck

# SQLite (alternativ — skapar liu_sou_cache.db bredvid skriptet)
# DATABASE_URL=sqlite:///liu_sou_cache.db

# Aktivera/inaktivera SOU-sökning (search_sou och get_sou)
# Sätt till false om en annan MCP-server hanterar SOU-sökning i din installation
SOU_SOKNING_AKTIV=true

# Aktivera/inaktivera SOU-hämtning och -lagring (fetch_sou_content)
# Sätt till false om en annan MCP-server hanterar SOU-fulltext i din installation
# OBS: Fulltext lagras i liu_sou.pdf_cache — inaktivera för att undvika dubbellagring
SOU_HAMTNING_AKTIV=true
